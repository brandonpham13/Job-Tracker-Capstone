{
    "name": "job-tracker-server",
    "version": "0.1.0",
    "private": true,
    "description": "Backend API for the Job Application Tracker",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "typecheck": "tsc --noEmit",
        "prisma:migrate": "prisma migrate dev",
        "prisma:generate": "prisma generate"
    },
    "dependencies": {
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "dotenv": "^17.4.2",
        "express": "^4.21.1"
    },
    "devDependencies": {
        "@types/express": "^5.0.0",
        "@types/node": "^22.9.0",
        "prisma": "^7.8.0",
        "tsx": "^4.19.2",
        "typescript": "^5.6.3"
    }
}
